{
  "name": "roq/aster_futures/flags/WS",
  "type": "flags",
  "prefix": "ws_",
  "values": [
    {
      "name": "uri",
      "type": "roq/io/web/URI",
      "validator": "roq/core/flags/URI",
      "default": "wss://fstream.asterdex.com/",
      "description": "Exchange end-point"
    },
    {
      "name": "ping_freq",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "request_timeout",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "15s",
      "description": "Request timeout"
    },
    {
      "name": "request_limit",
      "type": "std/uint32",
      "default": "5",
      "description": "Request limit per interval"
    },
    {
      "name": "request_limit_interval",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "1s",
      "description": "Request limit monitor interval"
    },
    {
      "name": "request_delay",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "1s",
      "description": "Request timeout"
    },
    {
      "name": "max_subscriptions_per_stream",
      "type": "std/uint32",
      "required": true,
      "default": 30,
      "description": "Maximum number of symbols per connection"
    },
    {
      "name": "mbp_request_delay",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "500ms",
      "description": "Request delay"
    },
    {
      "name": "mbp_request_max_retries",
      "type": "std/uint32",
      "default": 3,
      "description": "Request max retries"
    }
  ]
}
